    "preview": "vite preview",
    "clean": "rm -rf build",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.50.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
